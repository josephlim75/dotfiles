term = xterm-256color
theme = "Nord"
font-size=15
window-height=30
window-width=110
quit-after-last-window-closed=true
auto-update = off
#macos-option-as-alt = true

## Mouse select copy to clipboard
copy-on-select = clipboard

## Clipboard
clipboard-read = "allow"
clipboard-paste-protection = false

## Numpad + to increase font
## ghostty +list-keybinds --default
keybind = super+kp_add=increase_font_size:1

## https://github.com/ghostty-org/ghostty/issues/189 (Search GTK)
keybind = cmd+f=search:Ghostty
keybind = shift+cmd+f=search:
#keybind = super+f=write_scrollback_file:open

## Set cursor to block
cursor-style = block
shell-integration-features= no-cursor

