#!/bin/bash

require_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || return 1
  return 0
}

require_cmds() {
  local cmd

  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || return 1
  done
  return 0
}


setup_passwordless() {
  # Set passwordless sudo
  USER_NAME=$(whoami)
  echo "${USER_NAME} ALL=(ALL) NOPASSWD: ALL" | \
  sudo tee /etc/sudoers.d/${USER_NAME}
  sudo chmod 444 /etc/sudoers.d/${USER_NAME}
  sudo visudo -cf /etc/sudoers.d/${USER_NAME}
}

setup_xcode_cli() {
  # Install XCode CLI (Mandatory)
  [[ -d "/Library/Developer/CommandLineTools" ]] && return 0
  sudo rm -rf /Library/Developer/CommandLineTools
  xcode-select --install
}

setup_brew_cli() {

  require_cmd "brew" || {
    # Install Brew CLI
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    echo >> ${HOME}/.zprofile
    grep -q '/opt/homebrew/bin/brew shellenv' "${HOME}/.zprofile" 2>/dev/null || \
      echo 'eval "$(/opt/homebrew/bin/brew shellenv zsh)"' >> "${HOME}/.zprofile"
    eval "$(/opt/homebrew/bin/brew shellenv zsh)"
  }
}


setup_screenlock() {
  sudo pmset -a sleep 0
  sudo pmset -a displaysleep 0
}

setup_ohmyzsh() {
  [[ -d "${HOME}/.oh-my-zsh" ]] && return 0
  echo "star"
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/robbyrussell/oh-my-zsh/master/tools/install.sh)"
}

main() {
  setup_passwordless
  setup_xcode_cli
  setup_brew_cli
  setup_screenlock
  setup_ohmyzsh
}

main "$@"

